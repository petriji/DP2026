{
    // Spell-checking for this project content
    "cSpell.language": "en,cs",
    "cSpell.enabledFileTypes": {
        "*": false,
        "tex": true,
        "txt": true,
        "md": true
    },

    // BibTeX Manager integration used for bibliography key generation
    "libraryFilePath": "latex/%DOCFILE%-bibtexmanager",
    "useBibKeyPattern": true,
    "bibKeyPattern": "\\a(1)\\Y",
    "latex-workshop.bibtex-format.case.field": "UPPERCASE",

    // LaTeX build layout
    "latex-workshop.latex.outDir": "%DIR%/build",
    "latex-workshop.latex.texDirs": [
        "%DIR%/texparts",
        "%DIR%/texparts/python"
    ],
    "latex-workshop.latex.build.fromWorkspaceFolder": false,
    "latex-workshop.latex.autoBuild.run": "never",
    "latex-workshop.latex.autoClean.run": "onSucceeded",
    "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": false,
    "latex-workshop.latex.recipe.default": "lastUsed",

    // chktex linting — workspace override to onSave (machine-level has onType)
    "latex-workshop.linting.run": "onSave",

    // LaTeX build tools
    "latex-workshop.latex.tools": [
        {
            "name": "setup-venv",
            "command": "bash",
            "args": [
                "-c",
                "cd '%DIR%/../python' && bash setup_venv.sh"
            ]
        },
        {
            // Generate poster-specific PGF figures (*_poster.pgf) with
            // DP_POSTER_RUN=1 so poster typography tweaks do not affect thesis figures.
            "name": "poster-figures",
            "command": "bash",
            "args": [
                "-c",
                "mkdir -p '%DIR%/build' && set -o pipefail && cd '%DIR%/..' && bash python/run_poster_figures.sh 2>&1 | tee '%DIR%/build/poster-figures.log'"
            ]
        },
        {
            // Run Python analytics pipeline — regenerates missing figures/tables.
            "name": "stats-analytics",
            "command": "bash",
            "args": [
                "-c",
                "mkdir -p '%DIR%/build' && set -o pipefail && cd '%DIR%/..' && python/run.sh stats_analytics.py 2>&1 | tee '%DIR%/build/stats-analytics.log'"
            ]
        },
        {
            // Force-regenerate ALL figures/tables even when outputs already exist.
            // Useful after changing plot styles, color palettes, or table formatting.
            "name": "stats-analytics-force",
            "command": "bash",
            "args": [
                "-c",
                "mkdir -p '%DIR%/build' && set -o pipefail && cd '%DIR%/..' && python/run.sh stats_analytics.py --force all 2>&1 | tee '%DIR%/build/stats-analytics-force.log'"
            ]
        },
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                // "-shell-escape",  // needed only when tikzextern option is active
                "-output-directory=%DIR%/build",
                "%DOC%"
            ]
        },
        {
            "name": "biber",
            "command": "biber",
            "args": [
                "build/%DOCFILE%"
            ]
        },
        {
            // All configuration (pdf mode, synctex, pdflatex flags, outdir, biber,
            // normostrana/textchecks/citcount generation) is in latex/latexmkrc.
            "name": "latexmk",
            "command": "bash",
            "args": [
                "-c",
                "cd '%DIR%' && latexmk '%DOC%'; rc=$?; if [[ $rc -ne 0 ]] && grep -q 'needed too many passes' 'build/%DOCFILE%.log'; then echo '[latexmk-wrapper] Treating too-many-passes as success; continuing recipe.'; exit 0; fi; exit $rc"
            ]
        },
        {
            // Fully wipe the shared build/ directory used by all recipes.
            "name": "clean",
            "command": "bash",
            "args": [
                "-c",
                "cd '%DIR%' && shopt -s dotglob nullglob && rm -rf build/* build/.[!.]* build/..?* && echo 'Cleaned: build/'"
            ]
        },
        {
            // Copy build/main.pdf to the project root named from thesis metadata:
            //   SURNAME_(R)TYPELANG YEAR.pdf
            //     R    — present when draft option is uncommented in \documentclass[]
            //     TYPE — B (bachelor) | D (master/diplová) | Dis (doctoral)
            //     LANG — P (Czech) | T (English)
            //     YEAR — current calendar year
            "name": "publish",
            "command": "bash",
            "args": [
                "-c",
                "set +H; cd '%DIR%'; SURNAME=$(git config user.name 2>/dev/null | awk '{print $NF}' | iconv -f UTF-8 -t ASCII//TRANSLIT | tr a-z A-Z | tr -cd A-Z); YEAR=$(date +%Y); BLOCK=$(sed -n '/documentclass\\[/,/CTUthesis/p' main.tex | grep -Ev '^[[:space:]]*%'); echo \"$BLOCK\" | grep -qE '\\bdraft\\b' && R=R || R=; echo \"$BLOCK\" | grep -qE '\\bdoctoral\\b' && T=Dis || { echo \"$BLOCK\" | grep -qE '\\bmaster\\b' && T=D || T=B; }; echo \"$BLOCK\" | grep -qE '\\benglish\\b' && L=T || L=P; NAME=\"${SURNAME}_${R}${T}${L}${YEAR}.pdf\"; cp build/main.pdf '%DIR%/../'\"${NAME}\" && echo \"Published: ${NAME}\""
            ]
        },
        {
            // Copy build/poster.pdf to the project root with the same naming
            // convention as the thesis but with a _poster suffix:
            //   SURNAME_(R)TYPELANG YEAR_poster.pdf
            "name": "publish-poster",
            "command": "bash",
            "args": [
                "-c",
                "set +H; cd '%DIR%'; SURNAME=$(git config user.name 2>/dev/null | awk '{print $NF}' | iconv -f UTF-8 -t ASCII//TRANSLIT | tr a-z A-Z | tr -cd A-Z); YEAR=$(date +%Y); BLOCK=$(sed -n '/documentclass\\[/,/CTUthesis/p' main.tex | grep -Ev '^[[:space:]]*%'); echo \"$BLOCK\" | grep -qE '\\bdraft\\b' && R=R || R=; echo \"$BLOCK\" | grep -qE '\\bdoctoral\\b' && T=Dis || { echo \"$BLOCK\" | grep -qE '\\bmaster\\b' && T=D || T=B; }; echo \"$BLOCK\" | grep -qE '\\benglish\\b' && L=T || L=P; NAME=\"${SURNAME}_${R}${T}${L}${YEAR}_poster.pdf\"; cp build/poster.pdf '%DIR%/../'\"${NAME}\" && echo \"Published poster: ${NAME}\""
            ]
        },
        {
            // Remove all Python-generated outputs: figures (pics + local copies)
            // and LaTeX texpart snippets. After this, stats-analytics will
            // regenerate everything from scratch.
            "name": "clean-generated",
            "command": "bash",
            "args": [
                "-c",
                "cd '%DIR%/..' && rm -rf python/figures/* latex/texparts/python/* && echo 'Cleaned: python/figures, texparts/python'"
            ]
        },
        {
            // Build the poster PDF alongside the thesis.
            // Uses the same latexmkrc (outdir=build) so poster.pdf lands in build/.
            "name": "latexmk-poster",
            "command": "latexmk",
            "args": [
                "%DIR%/poster"
            ]
        },
        {
            // Build the standalone Python pipeline attachment PDF.
            // Run pdflatex twice to stabilize page-count-dependent references.
            "name": "pdflatex-python-pipeline-attachment",
            "command": "bash",
            "args": [
                "-c",
                "pdflatex -synctex=1 -interaction=nonstopmode -file-line-error -output-directory='%DIR%/build' '%DIR%/python_pipeline_attachment.tex' && pdflatex -synctex=1 -interaction=nonstopmode -file-line-error -output-directory='%DIR%/build' '%DIR%/python_pipeline_attachment.tex'"
            ]
        },
        {
            // Copy the standalone Python pipeline attachment to the project root.
            "name": "publish-python-pipeline-attachment",
            "command": "bash",
            "args": [
                "-c",
                "set +H; cd '%DIR%'; SURNAME=$(git config user.name 2>/dev/null | awk '{print $NF}' | iconv -f UTF-8 -t ASCII//TRANSLIT | tr a-z A-Z | tr -cd A-Z); YEAR=$(date +%Y); BLOCK=$(sed -n '/documentclass\\[/,/CTUthesis/p' main.tex | grep -Ev '^[[:space:]]*%'); echo \"$BLOCK\" | grep -qE '\\bdraft\\b' && R=R || R=; echo \"$BLOCK\" | grep -qE '\\bdoctoral\\b' && T=Dis || { echo \"$BLOCK\" | grep -qE '\\bmaster\\b' && T=D || T=B; }; echo \"$BLOCK\" | grep -qE '\\benglish\\b' && L=T || L=P; NAME=\"${SURNAME}_${R}${T}${L}${YEAR}_python_pipeline.pdf\"; cp build/python_pipeline_attachment.pdf '%DIR%/../'\"${NAME}\" && echo \"Published Python pipeline attachment: ${NAME}\""
            ]
        },
        {
            // Remove all cached data downloads (Eurostat, OECD, MPSV, etc.).
            // Next stats-analytics run will re-fetch everything from source APIs.
            "name": "clean-data",
            "command": "bash",
            "args": [
                "-c",
                "cd '%DIR%/..' && rm -rf python/data/* && echo 'Cleaned: python/data (will re-download on next run)'"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            // Quick update: latexmk only (git metadata + all checks + pdflatex + biber
            // as needed — latexmkrc handles the pre-flight computations automatically).
            "name": "Build",
            "tools": [
                "latexmk"
            ]
        },
        {
            // Build only the poster.
            "name": "Build Poster",
            "tools": [
                "latexmk-poster"
            ]
        },
        {
            // Poster workflow: regenerate poster-specific figures, then build poster PDF.
            "name": "Build Poster + Poster Figures",
            "tools": [
                "setup-venv",
                "poster-figures",
                "latexmk-poster"
            ]
        },
        {
            // Build only the standalone Python pipeline attachment.
            "name": "Build Attachment",
            "tools": [
                "pdflatex-python-pipeline-attachment"
            ]
        },
        {
            // Single pdflatex pass: assumes tmp files exist and references are stable.
            "name": "Build (fast)",
            "tools": [
                "pdflatex"
            ]
        },
        {
            // Regenerate missing Python figures/snippets, then rebuild with latexmk.
            "name": "Build + Analytics",
            "tools": [
                "setup-venv",
                "stats-analytics",
                "latexmk"
            ]
        },
//        {
//            // Force-regenerate ALL Python figures/snippets (even existing ones),
//            // then rebuild with latexmk. Use after changing plot styles or palettes.
//            "name": "Build + Force Analytics",
//            "tools": [
//                "setup-venv",
//                "stats-analytics-force",
//                "latexmk"
//            ]
//        },
        {
            // Force-regenerate all analytics (including poster-specific figures)
            // and rebuild all PDFs without cleaning. Skips data re-download and
            // build artifact cleanup — useful when you only need fresh figures/tables
            // and a full rebuild.
            "name": "Analytics + Build all",
            "tools": [
                "setup-venv",
                "poster-figures",
                "stats-analytics-force",
                "latexmk",
                "latexmk-poster",
                "pdflatex-python-pipeline-attachment"
            ]
        },
        {
            // Full local rebuild: clear cached data (force re-download),
            // wipe generated outputs/build artefacts, force-regenerate analytics,
            // and rebuild all PDFs.
            "name": "Clean + Analytics + Build all",
            "tools": [
                "clean-data",
                "clean-generated",
                "clean",
                "setup-venv",
                "stats-analytics-force",
                "latexmk",
                "latexmk-poster",
                "pdflatex-python-pipeline-attachment"
            ]
        },
        {
            // Full release build: same regeneration path as the clean build
            // (including data re-download + forced analytics), then publish
            // the resulting PDFs to the project root with release naming.
            "name": "Publish all",
            "tools": [
                "clean-data",
                "clean-generated",
                "clean",
                "setup-venv",
                "stats-analytics-force",
                "latexmk",
                "latexmk-poster",
                "pdflatex-python-pipeline-attachment",
                "publish",
                "publish-poster",
                "publish-python-pipeline-attachment"
            ]
        }
    ],

    // Auxiliary analysis related to this project output
    "latex-workshop.texcount.autorun": "onSave",
    "latex-utilities.countWord.format": "${charsBody} Characters in body",


