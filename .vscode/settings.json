{
    // Spell-checking for this project content
    "cSpell.language": "en,cs",

    // BibTeX Manager integration used for bibliography key generation
    "libraryFilePath": "latex/%DOCFILE%-bibtexmanager",
    "useBibKeyPattern": true,
    "bibKeyPattern": "\\a(1)\\Y",
    "latex-workshop.bibtex-format.case.field": "UPPERCASE",

    // LaTeX build layout
    "latex-workshop.latex.outDir": "%DIR%/build",
    "latex-workshop.latex.texDirs": [
        "%DIR%/texparts"
    ],
    "latex-workshop.latex.build.fromWorkspaceFolder": false,
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.latex.autoClean.run": "onSucceeded",
    "latex-workshop.latex.recipe.default": "lastUsed",

    // LaTeX build tools
    "latex-workshop.latex.tools": [
        {
            "name": "git-metadata",
            "command": "perl",
            "args": [
                "%DIR%/git-metadata.pl",
                "%DIR%/build"
            ]
        },
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                // "-shell-escape",  // needed only when tikzextern option is active
                "-output-directory=%DIR%/build",
                "%DOC%"
            ]
        },
        {
            "name": "biber",
            "command": "biber",
            "args": [
                "build/%DOCFILE%"
            ]
        },
        {
            // All configuration (pdf mode, synctex, pdflatex flags, outdir, biber,
            // normostrana/textchecks/citcount generation) is in latex/latexmkrc.
            "name": "latexmk",
            "command": "latexmk",
            "args": [
                "%DOC%"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            // Quick update: latexmk only (git metadata + all checks + pdflatex + biber
            // as needed — latexmkrc handles the pre-flight computations automatically).
            "name": "Update: latexmk",
            "tools": [
                "latexmk"
            ]
        }
    ],

    // Auxiliary analysis related to this project output
    "latex-workshop.texcount.autorun": "onSave",
    "latex-utilities.countWord.format": "${charsBody} Characters in body",


    // Recommended settings (user-scope)
    // "editor.wordWrap": "on",
    // "editor.renderWhitespace": "all",
    // "latex-workshop.linting.run": "onType",
    // "latex-workshop.linting.chktex.enabled": true,
    // "latex-workshop.linting.chktex.exec.args": [
    //     "-wall", "-n22", "-n30", "-e16", "-q",
    //     "-n1",  // Command terminated with space (false positives at line ends)
    //     "-n8",  // Wrong dash length (-- is correct Czech n-dash)
    //     "-n9",  // Bracket mismatch (false positives in acro package macros)
    //     "-n21", // \let assignments (\let\Author\@author etc.) flagged incorrectly
    //     "-n24"  // Space before \label (label on its own line after list/bib commands)
    // ],
    // "latex-workshop.synctex.afterBuild.enabled": true,
    // "latex-workshop.view.outline.sync.viewer": true,
    // "latex-workshop.view.pdf.scrollMode": 2,
    // "latex-workshop.view.pdf.zoom": "0.7",
    // "git.autofetch": true
}