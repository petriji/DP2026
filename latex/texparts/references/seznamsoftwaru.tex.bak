\chapter*{Seznam použitého softwaru}
\begin{itemize}[leftmargin=*]
\item \textbf{MATLAB R2018b} \textit{(System Identification Toolbox, Digital Signal Processing Toolbox)} - zpracování dat a grafické výstupy
\item \textbf{Tex Maker 5.0.2} \textit{(latex, tikz, biblatex, iso690, biber, acro, ocg, pdfpages, siunitx, hyperref, xltabular)} - sazba textu
\item \textbf{JabRef 4.2} - citační manažer
\item \textbf{Gimp 2.8} - úpravy obrázků
%\item \textbf{Word for Office 365} - sazba nečíslovaných stran
\end{itemize} 