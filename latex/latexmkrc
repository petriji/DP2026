$out_dir = 'build';

# ── Auto-generate figures before LaTeX build ──────────────────────────────────
# Calls python/stats_analytics.py to regenerate figure PDFs and .tex snippets.
# Skipped by default — run only when RUN_PYTHON_ANALYTICS=1 is set.
# Use the "Analytics + latexmk" VS Code recipe to trigger this automatically.
#
# The venv is resolved in order:
#   1. python/.venv   (created by python/setup_venv.sh, preferred)
#   2. ~/.venvs/dp_thesis  (legacy location)
#   3. plain python3  (system Python, if deps are installed globally)
{
    if ($ENV{RUN_PYTHON_ANALYTICS}) {
        my $proj   = $ENV{PWD};   # latex/ directory when latexmk is run there
        my $script = "$proj/../python/stats_analytics.py";

        if (-f $script) {
            my $venv1  = "$proj/../python/.venv/bin/python";
            my $venv2  = "$ENV{HOME}/.venvs/dp_thesis/bin/python";
            my $python = -f $venv1 ? $venv1
                       : -f $venv2 ? $venv2
                       : 'python3';

            my $rc = system($python, $script);
            if ($rc != 0) {
                die "stats_analytics.py failed (exit " . ($rc >> 8) . "). Aborting LaTeX build.\n";
            }
        }
    }
}
$pdf_mode = 1;       # use pdflatex
$bibtex_use = 2;     # use biber (not bibtex); 2 = delete .bbl on clean too
$biber = 'biber --input-directory=. %O %S';  # biber resolves .bib from source dir, not build/
# Pass synctex, nonstopmode, and file-line-error to every pdflatex invocation.
# The -shell-escape flag is needed only when the tikzextern option is active;
# uncomment the second line below and comment the first when required.
$pdflatex = 'pdflatex -synctex=1 -interaction=nonstopmode -file-line-error -cnf-line=extra_mem_bot=8000000 -cnf-line=extra_mem_top=8000000 %O %S';
# $pdflatex = 'pdflatex -synctex=1 -interaction=nonstopmode -file-line-error -shell-escape %O %S';

# Write generated TeX inputs only when their byte content changes.  latexmk
# tracks these .tmp files after TeX reads them; rewriting identical content on
# every pass creates a false rerun loop and can exhaust latexmk's pass limit.
sub ctu_write_if_changed {
    my ($target, $content) = @_;
    mkdir $out_dir unless -d $out_dir;
    if (-f $target && open my $in, '<', $target) {
        binmode $in;
        local $/;
        my $old = <$in>;
        close $in;
        return 0 if defined $old && $old eq $content;
    }
    open my $out, '>', $target or die "Cannot write $target: $!\n";
    binmode $out;
    print $out $content;
    close $out;
    return 1;
}

# Generate git author/email metadata files before each compilation.
# CTUthesis.cls reads these via \InputIfFileExists after inputenc is loaded.
# Written to $out_dir so they stay out of the source tree.
# Fallback placeholder text is used when git is unavailable or unconfigured.
{
    my $author = `git config user.name  2>/dev/null` // '';
    my $email  = `git config user.email 2>/dev/null` // '';
    chomp $author;  chomp $email;
    $author ||= 'Name Surname';
    $email  ||= 'address@e-mail.xy';
    ctu_write_if_changed("$out_dir/main-gitauthor.tmp", '\gdef\@author{' . $author . "}\n");
    ctu_write_if_changed("$out_dir/main-gitemail.tmp",  '\gdef\@email{'  . $email  . "}\n");
}

# ---------------------------------------------------------------------------
# Mtime helper — returns 1 when any of @sources is newer than $target,
# or when $target does not exist yet.  Used to skip texcount when unchanged.
sub ctu_needs_update {
    my ($target, @sources) = @_;
    return 1 unless -f $target;
    my $t = (stat($target))[9];
    for my $s (@sources) {
        return 1 if -f $s && (stat($s))[9] > $t;
    }
    return 0;
}

# Auto-compute normostrana (Czech standard pages = 1800 chars) using texcount.
# The result is written to build/main-normostrana.tmp and loaded by CTUthesis.cls
# at \AtBeginDocument only when \normostrana{} has NOT been set manually.
#
# Only body text chars are counted (N from "N+M+P" = text, no headers/captions),
# and only within regions NOT wrapped in %TC:ignore...%TC:endignore in main.tex
# (so front matter, TOC, and acronym lists are excluded from the count).
# This matches the Czech normostrana standard (body text only, ČSN ISO 5966).
#
# texcount is skipped when no .tex file is newer than the cached tmp — this
# avoids running it on every incremental recompile that touches only .bib or
# other non-.tex files.
{
    my $tmp = "$out_dir/main-normostrana.tmp";
    mkdir $out_dir unless -d $out_dir;
    if (ctu_needs_update($tmp, 'main.tex', glob('texparts/*.tex'))) {
        my $tc = `texcount -brief -char -inc main.tex 2>/dev/null`;
        # texcount outputs one "N+M+P (…) File: …" line per file and a final
        # "N+M+P … File(s) total:" summary.  Grab the LAST N+M+P match so we
        # always use the grand total (sum across all -inc'd files) and %TC:ignore
        # regions are already excluded by texcount before the sum is printed.
        # Use body chars only (first number N = text, excludes headers / captions).
        my $total = 0;
        while ($tc =~ /(\d+)\+\d+\+\d+/g) { $total = $1; }
        if ($total > 0) {
            # Round to nearest normostrana (round half-up).
            my $normo = int(($total + 900) / 1800);
            $normo = 1 if $normo < 1;
            ctu_write_if_changed($tmp, '\normostrana{' . $normo . "}\n");
        }
    }
}

# Compute body character counts for abstract and keyword files.
# texcount -brief -char returns "N+M+P" where N = body text chars.
# Value -1 is written when the file does not exist or texcount fails;
# CTUthesis.cls treats -1 as "no data" and skips the corresponding check.
# Each file is checked individually so only changed files re-run texcount.
{
    sub ctu_texcount_chars {
        my ($file) = @_;
        return -1 unless -f $file;
        my $tc = `texcount -brief -char "$file" 2>/dev/null`;
        return $1 if $tc =~ /(\d+)\+\d+\+\d+/;
        return -1;
    }
    my $tmp = "$out_dir/main-textchecks.tmp";
    mkdir $out_dir unless -d $out_dir;
    my @srcs = ('texparts/mandatory/abstract.tex', 'texparts/mandatory/abstract_en.tex',
                'texparts/mandatory/keywords.tex', 'texparts/mandatory/keywords_en.tex');
    if (ctu_needs_update($tmp, @srcs)) {
        my $na  = ctu_texcount_chars('texparts/mandatory/abstract.tex');
        my $nae = ctu_texcount_chars('texparts/mandatory/abstract_en.tex');
        my $nk  = ctu_texcount_chars('texparts/mandatory/keywords.tex');
        my $nke = ctu_texcount_chars('texparts/mandatory/keywords_en.tex');
        my $content = "\\makeatletter\n"
                    . '\gdef\@CTUabstractchars{'   . $na  . "}\n"
                    . '\gdef\@CTUabstractenchars{' . $nae . "}\n"
                    . '\gdef\@CTUkeywordschars{'   . $nk  . "}\n"
                    . '\gdef\@CTUkeywordsenchars{' . $nke . "}\n"
                    . "\\makeatother\n";
        ctu_write_if_changed($tmp, $content);
    }
}

# Count cited bibliography entries from the .bbl file produced by biber.
# biblatex .bbl files contain one \entry{key}{type}{...} line per cited work.
#
# This runs via $pre_pdf_code (before EACH pdflatex pass) rather than once at
# startup.  That way, when biber produces a fresh .bbl mid-session (between
# pdflatex passes), the updated count is available for the very next pass —
# avoiding the "0 entries" warning that would otherwise persist for the rest
# of the current build.  The mtime guard ensures the file is only rewritten
# when the .bbl has actually changed.
sub ctu_update_citcount {
    my $bbl = "$out_dir/main.bbl";
    my $tmp = "$out_dir/main-citcount.tmp";
    return unless ctu_needs_update($tmp, $bbl);
    my $count = 0;
    if (-f $bbl && open my $fh, '<', $bbl) {
        while (<$fh>) { $count++ if /\\entry\{/; }
        close $fh;
    }
    my $content = "\\makeatletter\n"
                . '\gdef\@CTUcitcount{' . $count . "}\n"
                . "\\makeatother\n";
    ctu_write_if_changed($tmp, $content);
}
add_hook('before_xlatex', \&ctu_update_citcount);

# ---------------------------------------------------------------------------
# Poster metadata — figure / table / attachment counts + git repo URL & tag.
# Written to build/main-stats.tmp and consumed by CTUposter.cls so the poster
# can display thesis-level totals without re-typesetting the thesis itself.
#
# Counts:
#   figures      — \contentsline {figure} entries in build/main.lof
#   tables       — \contentsline {table}  entries in build/main.lot
#                  (fallback: corresponding \@writefile entries in build/main.aux)
#   attachments  — \item lines in texparts/references/list_attachments.tex
#                  (simple regex; ignores commented-out lines)
# Git:
#   repo URL is normalised to https://host/owner/repo  (strips .git, ssh→https)
#   tag is the most recent annotated tag matching `git describe --tags`.
#   When no tag exists yet (e.g. the publication tag has not been created),
#   we fall back to the current short commit hash; both URL fragments are
#   exposed so the class can choose.  The user may override either via
#   \posterrepo{}/\posterrepotag{} in the poster preamble.
sub ctu_update_poster_stats {
    my $tmp = "$out_dir/main-stats.tmp";
    my $lof = "$out_dir/main.lof";
    my $lot = "$out_dir/main.lot";
    my $aux = "$out_dir/main.aux";
    my $att = 'texparts/references/list_attachments.tex';

    # mtime guard: rerun when any source is newer than the tmp.
    return unless ctu_needs_update($tmp, $lof, $lot, $aux, $att);

    my $nfig = 0;
    if (-f $lof && open my $fh, '<', $lof) {
        while (<$fh>) { $nfig++ if /\\contentsline\s*\{figure\}/; }
        close $fh;
    }
    if ($nfig == 0 && -f $aux && open my $fh, '<', $aux) {
        while (<$fh>) { $nfig++ if /\\\@writefile\{lof\}\{\\contentsline\s*\{figure\}/; }
        close $fh;
    }
    my $ntab = 0;
    if (-f $lot && open my $fh, '<', $lot) {
        while (<$fh>) { $ntab++ if /\\contentsline\s*\{table\}/; }
        close $fh;
    }
    if ($ntab == 0 && -f $aux && open my $fh, '<', $aux) {
        while (<$fh>) { $ntab++ if /\\\@writefile\{lot\}\{\\contentsline\s*\{table\}/; }
        close $fh;
    }
    my $natt = 0;
    if (-f $att && open my $fh, '<', $att) {
        while (<$fh>) {
            next if /^\s*%/;          # skip full-line comments
            $natt++ if /(?<!\\)\\item\b/;
        }
        close $fh;
    }

    # Git remote URL → normalised https form.
    my $remote = `git config --get remote.origin.url 2>/dev/null` // '';
    chomp $remote;
    my $repo = '';
    if ($remote =~ m{^git\@([^:]+):(.+?)(?:\.git)?$}) {
        $repo = "https://$1/$2";
    } elsif ($remote =~ m{^https?://[^/]+/.+}) {
        $repo = $remote;
        $repo =~ s/\.git$//;
    }

    # Latest tag (may not exist yet — that's intentional, see class doc).
    my $tag = `git describe --tags --abbrev=0 2>/dev/null` // '';
    chomp $tag;
    # Short commit hash as a fallback "ref".
    my $sha = `git rev-parse --short HEAD 2>/dev/null` // '';
    chomp $sha;

    my $content = "\\makeatletter\n"
                . '\gdef\@CTUnfigures{'     . $nfig . "}\n"
                . '\gdef\@CTUntables{'      . $ntab . "}\n"
                . '\gdef\@CTUnattachments{' . $natt . "}\n"
                . '\gdef\@CTUgitrepo{'      . $repo . "}\n"
                . '\gdef\@CTUgittag{'       . $tag  . "}\n"
                . '\gdef\@CTUgitsha{'       . $sha  . "}\n"
                . "\\makeatother\n";
    ctu_write_if_changed($tmp, $content);
}
add_hook('before_xlatex', \&ctu_update_poster_stats);